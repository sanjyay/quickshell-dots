#!/bin/bash
# Quickshell Rise — restore the persisted UI provider mode at session start.
if command -v qs-mode >/dev/null 2>&1; then
  qs-mode "$(qs-mode status 2>/dev/null || printf quickshell)" >/dev/null 2>&1 || true
else
  pkill -x waybar 2>/dev/null || true
  setsid qs -n -d -c bar >/dev/null 2>&1 < /dev/null &
fi
