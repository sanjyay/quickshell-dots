#!/usr/bin/env python3
"""
OpenCode local usage for the Quickshell AI usage widget.

OpenCode does not expose a Claude/Codex-style 5h/7d quota locally. This script
reads OpenCode's local SQLite session aggregates and writes the same cache shape
the widget already understands, using configurable soft caps for the visual
usage bars. It never reads API tokens and never makes network calls.
"""
import json
import os
import sqlite3
import time
from datetime import datetime
from pathlib import Path

DATA_DIR = Path(os.environ.get("OPENCODE_DATA_DIR") or (Path.home() / ".local" / "share" / "opencode"))
DB_FILE = DATA_DIR / "opencode.db"
CACHE_FILE = Path.home() / ".cache" / "opencode-usage.json"

DEFAULT_5H_LIMIT = 1_000_000
DEFAULT_7D_LIMIT = 20_000_000


def env_int(name: str, default: int) -> int:
    try:
        value = int(os.environ.get(name, ""))
        return value if value > 0 else default
    except Exception:
        return default


LIMIT_5H = env_int("OPENCODE_USAGE_5H_LIMIT", DEFAULT_5H_LIMIT)
LIMIT_7D = env_int("OPENCODE_USAGE_7D_LIMIT", DEFAULT_7D_LIMIT)


def stale_last() -> None:
    if not CACHE_FILE.exists():
        return
    try:
        cur = json.loads(CACHE_FILE.read_text())
        cur["_source"] = "stale"
        CACHE_FILE.write_text(json.dumps(cur))
    except Exception:
        pass


def connect() -> sqlite3.Connection:
    con = sqlite3.connect(f"file:{DB_FILE}?mode=ro", uri=True, timeout=2.0)
    con.execute("pragma busy_timeout=2000")
    return con


def total_expr() -> str:
    return (
        "coalesce(tokens_input,0) + coalesce(tokens_output,0) + "
        "coalesce(tokens_reasoning,0) + coalesce(tokens_cache_read,0) + "
        "coalesce(tokens_cache_write,0)"
    )


def sum_since(con: sqlite3.Connection, since_ms: int) -> tuple[int, float]:
    expr = total_expr()
    row = con.execute(
        f"select coalesce(sum({expr}),0), coalesce(sum(cost),0) "
        "from session where time_updated >= ?",
        (since_ms,),
    ).fetchone()
    return int(row[0] or 0), float(row[1] or 0.0)


def model_label(raw: str) -> str:
    try:
        model = json.loads(raw)
        mid = model.get("id") or ""
        provider = model.get("providerID") or ""
        variant = model.get("variant") or ""
        name = mid + (":" + variant if variant else "")
        return name + (f" ({provider})" if provider else "")
    except Exception:
        return str(raw or "")


def newest_model(con: sqlite3.Connection) -> str:
    row = con.execute(
        "select model from session where model is not null and model != '' "
        "order by time_updated desc limit 1"
    ).fetchone()
    return model_label(row[0]) if row else ""


def fmt_tokens(value: int) -> str:
    if value >= 1_000_000:
        return f"{value / 1_000_000:.1f}M"
    if value >= 1_000:
        return f"{value / 1_000:.1f}K"
    return str(value)


def model_rows(con: sqlite3.Connection, today_ms: int, limit: int = 6) -> list[dict]:
    rows = con.execute(
        """
        select model,
               count(*) as sessions,
               coalesce(sum(tokens_input),0) as input,
               coalesce(sum(tokens_output),0) as output,
               coalesce(sum(tokens_reasoning),0) as reasoning,
               coalesce(sum(tokens_cache_read),0) as cache_read,
               coalesce(sum(tokens_cache_write),0) as cache_write,
               coalesce(sum(cost),0) as cost,
               max(time_updated) as last_seen
        from session
        where model is not null and model != ''
        group by model
        order by (
          coalesce(sum(tokens_input),0) + coalesce(sum(tokens_output),0) +
          coalesce(sum(tokens_reasoning),0) + coalesce(sum(tokens_cache_read),0) +
          coalesce(sum(tokens_cache_write),0)
        ) desc
        limit ?
        """,
        (limit,),
    ).fetchall()
    today_by_model = {
        row[0]: int(row[1] or 0)
        for row in con.execute(
            f"""
            select model, coalesce(sum({total_expr()}),0)
            from session
            where time_updated >= ? and model is not null and model != ''
            group by model
            """,
            (today_ms,),
        ).fetchall()
    }
    totals = []
    for raw, sessions, inp, out, reasoning, cache_read, cache_write, cost, last_seen in rows:
        total = int(inp or 0) + int(out or 0) + int(reasoning or 0) + int(cache_read or 0) + int(cache_write or 0)
        totals.append({
            "name": model_label(raw),
            "sessions": int(sessions or 0),
            "total": total,
            "totalLabel": fmt_tokens(total),
            "inputLabel": fmt_tokens(int(inp or 0)),
            "outputLabel": fmt_tokens(int(out or 0)),
            "reasoningLabel": fmt_tokens(int(reasoning or 0)),
            "cacheReadLabel": fmt_tokens(int(cache_read or 0)),
            "cacheWriteLabel": fmt_tokens(int(cache_write or 0)),
            "todayLabel": fmt_tokens(today_by_model.get(raw, 0)),
            "costLabel": f"${float(cost or 0.0):.2f}" if float(cost or 0.0) > 0 else "",
            "lastSeen": int(last_seen or 0),
        })
    max_total = max((row["total"] for row in totals), default=0)
    for row in totals:
        row["pct"] = int(round(row["total"] * 100 / max_total)) if max_total else 0
    return totals


def pct(tokens: int, limit: int) -> float:
    if limit <= 0:
        return 0.0
    return min(1.0, max(0.0, tokens / float(limit)))


def main() -> None:
    if not DB_FILE.exists():
        stale_last()
        return

    now = time.time()
    five_h_ms = int((now - 5 * 3600) * 1000)
    seven_d_ms = int((now - 7 * 24 * 3600) * 1000)
    hour_ms = int((now - 3600) * 1000)
    start_today = datetime.now().replace(hour=0, minute=0, second=0, microsecond=0).timestamp()
    today_ms = int(start_today * 1000)

    try:
        con = connect()
        with con:
            tok_5h, cost_5h = sum_since(con, five_h_ms)
            tok_7d, cost_7d = sum_since(con, seven_d_ms)
            tok_1h, _ = sum_since(con, hour_ms)
            tok_today, cost_today = sum_since(con, today_ms)
            model = newest_model(con)
            models = model_rows(con, today_ms)
    except sqlite3.Error:
        stale_last()
        return

    out = {
        "5h-utilization": f"{pct(tok_5h, LIMIT_5H):.4f}",
        "5h-reset": "0",
        "7d-utilization": f"{pct(tok_7d, LIMIT_7D):.4f}",
        "7d-reset": "0",
        "updated_at": datetime.now().strftime("%H:%M:%S"),
        "_source": "sqlite",
        "_plan": "local",
        "_model": model,
        "_models": models,
        "_tokens_used": tok_5h,
        "_window_limit": LIMIT_5H,
        "_rate_per_hour": tok_1h,
        "_today_tokens": tok_today,
        "_7d_tokens": tok_7d,
        "_7d_limit": LIMIT_7D,
        "_cost_5h": cost_5h,
        "_cost_7d": cost_7d,
        "_cost_today": cost_today,
        "status": "allowed_warning" if tok_5h >= LIMIT_5H * 0.9 else "allowed",
    }
    CACHE_FILE.parent.mkdir(parents=True, exist_ok=True)
    CACHE_FILE.write_text(json.dumps(out))


if __name__ == "__main__":
    main()
