#!/usr/bin/env python3
"""
Claude Code quota for the Quickshell bar widget.

Reads the OAuth access token Claude Code already stores in
~/.claude/.credentials.json and queries the same authoritative endpoint that
powers Claude Code's own `/usage` command — no browser, no cookie, 0 tokens.

Writes ~/.cache/claude-usage.json in the format the widget reads. The 5h/7d
percentages come straight from the server; the token breakdown shown in the
tooltip is a lightweight local count over the current 5h window.
"""
import json, re, subprocess, sys, urllib.request, urllib.error
from datetime import datetime, timezone
from pathlib import Path

CRED_FILE  = Path.home() / ".claude" / ".credentials.json"
CACHE_FILE = Path.home() / ".cache"  / "claude-usage.json"
PROJECTS   = Path.home() / ".claude" / "projects"
ENDPOINT   = "https://api.anthropic.com/api/oauth/usage"


def claude_version() -> str:
    try:
        out = subprocess.run(["claude", "--version"],
                             capture_output=True, text=True, timeout=5).stdout
        m = re.search(r"\d+\.\d+\.\d+", out)
        if m:
            return m.group()
    except Exception:
        pass
    return "2.0.0"


def access_token() -> str | None:
    try:
        return json.loads(CRED_FILE.read_text())["claudeAiOauth"]["accessToken"]
    except Exception:
        return None


def fetch_usage(token: str) -> dict | None:
    req = urllib.request.Request(ENDPOINT, headers={
        "Authorization":  f"Bearer {token}",
        "anthropic-beta": "oauth-2025-04-20",
        "User-Agent":     f"claude-code/{claude_version()}",
        "Content-Type":   "application/json",
    })
    try:
        with urllib.request.urlopen(req, timeout=15) as r:
            return json.loads(r.read())
    except urllib.error.HTTPError as e:
        sys.stderr.write(f"HTTP {e.code}: {e.reason}\n")
    except Exception as e:
        sys.stderr.write(f"fetch error: {e}\n")
    return None


def iso_ts(s: str) -> int:
    try:
        return int(datetime.fromisoformat(s.replace("Z", "+00:00")).timestamp())
    except Exception:
        return 0


def count_tokens_since(since_ts: int) -> tuple[int, int, int]:
    """(tokens_in_window, tokens_in_last_hour, tokens_today) from local JSONL."""
    now = datetime.now(timezone.utc).timestamp()
    today = datetime.now(timezone.utc).strftime("%Y-%m-%d")
    total = recent = today_total = 0
    for f in PROJECTS.glob("**/*.jsonl"):
        try:
            if f.stat().st_mtime < since_ts:      # untouched before the window → skip fast
                continue
            for line in f.read_text().splitlines():
                if '"usage"' not in line:
                    continue
                e = json.loads(line)
                msg = e.get("message", {})
                if msg.get("role") != "assistant":
                    continue
                ts = iso_ts(e.get("timestamp", ""))
                if ts < since_ts:
                    continue
                u = msg.get("usage", {})
                tok = (u.get("input_tokens", 0) + u.get("output_tokens", 0)
                       + u.get("cache_read_input_tokens", 0)
                       + u.get("cache_creation_input_tokens", 0))
                total += tok
                if ts >= now - 3600:
                    recent += tok
                if e.get("timestamp", "")[:10] == today:
                    today_total += tok
        except Exception:
            continue
    return total, recent, today_total


def main():
    token = access_token()
    data  = fetch_usage(token) if token else None

    # Fall back to the last good cache if the fetch failed (e.g. token expired
    # while Claude Code isn't running) — keeps the last numbers on screen.
    if not data:
        if CACHE_FILE.exists():
            cur = json.loads(CACHE_FILE.read_text())
            cur["_source"] = "stale"
            CACHE_FILE.write_text(json.dumps(cur))
        return

    fh = data.get("five_hour") or {}
    sd = data.get("seven_day") or {}
    util5h  = (fh.get("utilization") or 0) / 100.0
    util7d  = (sd.get("utilization") or 0) / 100.0
    reset5h = iso_ts(fh.get("resets_at", ""))
    reset7d = iso_ts(sd.get("resets_at", ""))

    window_start = reset5h - 5 * 3600 if reset5h else int(datetime.now().timestamp()) - 5 * 3600
    tokens, recent, today_tokens = count_tokens_since(window_start)
    limit = int(tokens / util5h) if util5h > 0 and tokens else 0

    out = {
        "5h-utilization": f"{util5h:.4f}",
        "5h-reset":       str(reset5h),
        "7d-utilization": f"{util7d:.4f}",
        "7d-reset":       str(reset7d),
        "updated_at":     datetime.now().strftime("%H:%M:%S"),
        "_source":        "oauth",
        "_tokens_used":   tokens,
        "_window_limit":  limit,
        "_rate_per_hour": recent,
        "_today_tokens":  today_tokens,
        "status": "rejected" if util5h >= 1.0
                  else "allowed_warning" if util5h >= 0.9
                  else "allowed",
    }
    CACHE_FILE.write_text(json.dumps(out))


if __name__ == "__main__":
    main()
